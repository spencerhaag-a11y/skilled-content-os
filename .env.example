# ── Frontend (Vite) ─────────────────────────────────────────────
# Safe to expose to the browser. Copy to .env.local and fill in.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Supabase Edge Function secrets ──────────────────────────────
# NEVER put these in any VITE_ variable or client code.
# Set via: supabase secrets set KEY=value
# ANTHROPIC_API_KEY=          Claude API — all content generation (claude-sonnet-4-6)
# ASSEMBLYAI_API_KEY=         Video/audio transcription (Module 8)
# ASSEMBLYAI_WEBHOOK_SECRET=  Shared secret AssemblyAI echoes back to video-webhook (any random string)
# SERVICE_ROLE_KEY=           Service-role key for video-webhook (Supabase blocks the SUPABASE_ prefix on custom secrets)
# (GHL API keys are stored per-account in the database, encrypted — Section 6)
